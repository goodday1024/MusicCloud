OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.gptgod.online/v1
OPENAI_MODEL=gpt-4.1-mini
OPENAI_TTS_API_KEY=
OPENAI_TTS_BASE_URL=https://api.gptgod.online/v1
OPENAI_TTS_PATH=/audio/speech
OPENAI_TTS_RESPONSE_FORMAT=mp3
OPENAI_TTS_MODEL=tts-1-hd
OPENAI_TTS_VOICE=alloy
PORT=8787

# Frontend / Electron API base URL. Desktop builds route /api and /media here.
VITE_API_BASE_URL=https://zihang.fun

# Vercel/serverless: optional but recommended for stable Netease login.
# Paste your browser Netease Music cookie here in Vercel Project Settings.
NETEASE_COOKIE=

# Optional but recommended for stable QQ Music access.
# Paste the Cookie from https://y.qq.com after logging in.
QQMUSIC_COOKIE=

# Experimental QQ scan login. Override with values captured from y.qq.com if Tencent changes login params.
QQMUSIC_QR_APPID=716027609
QQMUSIC_QR_CALLBACK=https://y.qq.com/portal/profile.html

# Vercel Blob: strongly recommended for generated podcast audio URLs.
# Create a Vercel Blob store and let Vercel add this token automatically,
# or paste it in Project Settings > Environment Variables.
BLOB_READ_WRITE_TOKEN=

# Vercel/serverless writable temp directory. Leave empty locally.
AGENTIO_RUNTIME_DIR=

# Optional binary overrides. The project bundles ffmpeg/ffprobe installers by default.
FFMPEG_PATH=
FFPROBE_PATH=

# Optional: create a macOS Shortcut that routes playback to a HomePod,
# then put its exact name here. The backend calls `shortcuts run <name>`.
HOMEPOD_SHORTCUT_NAME=

# Optional music aggregation API, compatible with the article's PHP endpoints:
# https://your-domain.com/netease.php?msg=keyword&type=song&count=10&page=1
MUSIC_API_BASE_URL=
# Optional: GitHub-ZC/wp_MusicApi service base URL, e.g. http://localhost:5000
WP_MUSIC_API_BASE_URL=
# Preferred QQ Music API service: goodday1024/QQMusicApi1 web service.
# Public test service used by this project: http://49.51.189.172:8000
QQMUSIC_API1_BASE_URL=http://49.51.189.172:8000
# QQ resolver strategy inspired by CharlesPikachu/musicdl.
# It tries official musicu.fcg first, then optional third-party resolvers.
QQMUSIC_CHARLES_MUSICDL_FALLBACK=true
QQMUSIC_CHARLES_MUSICDL_APIS=nki,tang,xunhuisi,lpz,lxmusic,vkeys
# Optional third-party resolver keys. Leave empty unless you own valid keys.
QQMUSIC_NKI_API_KEYS=
QQMUSIC_XIANYUW_API_KEYS=
QQMUSIC_CY_API_KEYS=
QQMUSIC_LXMUSIC_REQUEST_KEY=share-v3
NETEASE_API_BASE_URL=
LOCAL_MUSIC_API_DIR=/Users/zhangzihang/music-api
MUSIC_API_DEFAULT_PLATFORM=netease
