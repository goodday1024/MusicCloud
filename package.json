{
  "name": "music-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "dev:fullstack": "concurrently \"node server/index.js\" \"vite --host 0.0.0.0\"",
    "dev:electron": "concurrently \"vite --host 0.0.0.0\" \"wait-on http://localhost:5173 && VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "server": "node server/index.js",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0",
    "pack:mac": "npm run build && electron-builder --mac --dir",
    "dist:mac": "npm run build && electron-builder --mac"
  },
  "build": {
    "appId": "fun.zihang.caelumshao",
    "productName": "云韶 CaelumShao",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "mac": {
      "category": "public.app-category.music",
      "target": [
        "dmg",
        "zip"
      ]
    }
  },
  "dependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@ffprobe-installer/ffprobe": "^2.1.2",
    "@vercel/blob": "^2.4.1",
    "@vitejs/plugin-react": "^4.5.2",
    "concurrently": "^9.2.0",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^4.21.2",
    "lucide-react": "^0.468.0",
    "multer": "^2.2.0",
    "nanoid": "^5.1.5",
    "NeteaseCloudMusicApi": "^4.32.0",
    "openai": "^4.104.0",
    "qq-login-qr": "^1.0.3",
    "qq-music-api": "^1.1.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.184.0",
    "three-globe": "^2.45.2",
    "vite": "^6.3.5"
  },
  "devDependencies": {
    "electron": "^41.7.1",
    "electron-builder": "^26.15.3",
    "wait-on": "^9.0.10"
  }
}
