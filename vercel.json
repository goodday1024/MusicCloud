{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "functions": {
    "api/[...all].js": {
      "maxDuration": 60,
      "memory": 1024,
      "includeFiles": "node_modules/@{ffmpeg-installer,ffprobe-installer}/**"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/[...all].js" },
    { "source": "/media/(.*)", "destination": "/api/[...all].js" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
